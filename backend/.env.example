# ── LLM Providers ─────────────────────────────────────────────────────────────
# At least one provider key is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

DEFAULT_PROVIDER=openai
ORCHESTRATOR_MODEL=gpt-4o
SPECIALIST_MODEL=gpt-4o
EVALUATOR_MODEL=gpt-4o-mini

# ── Infrastructure ─────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
REDIS_URL=redis://localhost:6379

# ── Jira Integration ──────────────────────────────────────────────────────────
# Obtain a token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_TOKEN=
JIRA_PROJECT_KEY=QE

# ── Security ──────────────────────────────────────────────────────────────────
# Set a strong random value (e.g. openssl rand -hex 32) to enable API key auth.
# Leave blank for development (auth is skipped).
APP_API_KEY=

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173

# ── Observability ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=backlog-synthesizer

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_TIMEOUT_SECONDS=600
MAX_RETRIES=2
USE_MOCK_BACKLOG=true
